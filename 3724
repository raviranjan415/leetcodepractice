#include <vector>
#include <algorithm>

using namespace std;

class Solution {
public:
    int maxPathScore(vector<vector<int>>& grid, int k) {
        int m = grid.size();
        int n = grid[0].size();
        int inf = 1 << 30;
        
        // f[row][col][remaining_cost]
        // Initialize with -1 to indicate uncalculated states
        vector<vector<vector<int>>> f(m, vector<vector<int>>(n, vector<int>(k + 1, -1)));

        // Lambda for DFS with memoization
        auto dfs = [&](auto&& dfs, int i, int j, int cur_k) -> int {
            // Out of bounds or exceeded cost limit
            if (i < 0 || j < 0 || cur_k < 0) {
                return -inf;
            }
            // Base case: Reached the starting point
            if (i == 0 && j == 0) {
                return 0;
            }
            // Return memoized result if it exists
            if (f[i][j][cur_k] != -1) {
                return f[i][j][cur_k];
            }

            int score = grid[i][j];
            int next_k = cur_k;
            // If the cell is 1 or 2, it costs 1 to visit
            if (grid[i][j] > 0) {
                --next_k;
            }

            // Move Up or Left
            int from_up = dfs(dfs, i - 1, j, next_k);
            int from_left = dfs(dfs, i, j - 1, next_k);

            int res = score + max(from_up, from_left);
            return f[i][j][cur_k] = res;
        };

        int ans = dfs(dfs, m - 1, n - 1, k);
        // If result is negative, no valid path within cost k exists
        return ans < 0 ? -1 : ans;
    }
};
