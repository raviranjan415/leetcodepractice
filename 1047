#include <string>
using namespace std;

class Solution {
public:
    string removeDuplicates(string s) {
        string res = "";
        for (char c : s) {
            // If the current character is the same as the last one added,
            // it's an adjacent duplicate, so we remove the last character.
            if (!res.empty() && res.back() == c) {
                res.pop_back();
            } else {
                // Otherwise, add the current character to our "stack".
                res.push_back(c);
            }
        }
        return res;
    }
};
